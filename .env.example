# .env.example
# 复制到 .env 后修改；docker compose 会自动读取。
#
#   cp .env.example .env

# ─── 镜像标签 ──────────────────────────────────────
# 推荐：用 git short sha 而不是 latest（CI 友好）
#   DOCKER_TAG=$(git rev-parse --short HEAD)
DOCKER_TAG=latest

# 镜像仓库前缀（推送到内网/远程时改）
#   本地构建：local（默认）
#   GitHub Container Registry：ghcr.io/miraclez3
#   阿里云：registry.cn-hangzhou.aliyuncs.com/your-ns
DOCKER_REGISTRY=local

# ─── 训练 GPU 数量 ─────────────────────────────────
TRAIN_NUM_GPUS=1

# ─── 命令追加参数（可选） ──────────────────────────
# 例如：DATA_EXTRA_ARGS="--skip-download"
DATA_EXTRA_ARGS=""
TOKENIZE_EXTRA_ARGS=""
EXTRACT_EXTRA_ARGS=""
TRAIN_EXTRA_ARGS=""
PIPELINE_EXTRA_ARGS=""
